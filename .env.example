# Required — the only key you need to run the app.
# All Gemini calls (deck drafting, slide revision, brand-check evals, image
# generation) run server-side through this key.
GOOGLE_API_KEY=

# Optional — model overrides. Defaults shown; delete the lines to use them.
GOOGLE_TEXT_MODEL=gemini-3-flash-preview
GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview
